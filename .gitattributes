# Shell scripts run on QNX — MUST stay LF (the web app serves these raw to the head unit).
*.sh    text eol=lf
# Firmware/driver/image binaries — never line-ending-convert (autocrlf would corrupt them).
*.so    binary
*.bin   binary
*.elf   binary
*.png   binary
*.zip   binary

# Extensionless SH4/QNX executables live in bin/ dirs -- protect by PATH (git NUL
# auto-detect is not guaranteed across commit environments; a single munged byte in
# a memory-patch binary bricks the head unit). Belt-and-suspenders over the ext rules.
**/bin/*    binary
*.o         binary
