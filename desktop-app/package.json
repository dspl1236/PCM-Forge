{
  "name": "pcm-forge",
  "version": "1.0.0",
  "description": "Porsche PCM 3.1 Activation Code Generator & ESP32 Device Programmer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64"
  },
  "author": "dspl1236",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "optionalDependencies": {
    "serialport": "^12.0.0"
  },
  "build": {
    "appId": "com.dspl1236.pcm-forge",
    "productName": "PCM-Forge",
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName": "PCM-Forge-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": true
    }
  }
}
